# Django Settings
DJANGO_SECRET_KEY=your-super-secret-key-here-change-in-production
DJANGO_DEBUG=True
DJANGO_SETTINGS_MODULE=odoo_cafe_pos.settings.local
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Database Configuration
DB_NAME=odoo_cafe_pos
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

# Redis Configuration (for WebSockets in production)
REDIS_URL=redis://localhost:6379/0

# CORS Settings
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Self-Order URL (for QR code generation)
SELF_ORDER_URL=http://localhost:3000/self-order/

# JWT Token Lifetimes (in hours)
JWT_ACCESS_TOKEN_LIFETIME=8
JWT_REFRESH_TOKEN_LIFETIME=24
